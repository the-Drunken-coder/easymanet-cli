#!/usr/bin/env python3
"""Minimal jsonfilter stub for provision.sh behavior tests."""

import json
import re
import sys


def load_json(path: str):
    with open(path, encoding="utf-8") as f:
        return json.load(f)


def walk(obj, keys):
    cur = obj
    for key in keys:
        if key == "":
            continue
        match = re.fullmatch(r"([^[]+)(?:\[(\d+)\])?", key)
        if not match:
            return None
        key = match.group(1)
        index = match.group(2)
        if isinstance(cur, dict):
            cur = cur.get(key)
        else:
            return None
        if index is not None:
            if not isinstance(cur, list):
                return None
            idx = int(index)
            if idx >= len(cur):
                return None
            cur = cur[idx]
    return cur


def main() -> int:
    if len(sys.argv) < 4 or "-e" not in sys.argv:
        return 1
    if "-i" in sys.argv:
        source_idx = sys.argv.index("-i") + 1
        if source_idx >= len(sys.argv):
            return 1
        data = load_json(sys.argv[source_idx])
    elif "-s" in sys.argv:
        source_idx = sys.argv.index("-s") + 1
        if source_idx >= len(sys.argv):
            return 1
        data = json.loads(sys.argv[source_idx])
    else:
        return 1
    expr_idx = sys.argv.index("-e") + 1
    if expr_idx >= len(sys.argv):
        return 1
    expr = sys.argv[expr_idx]

    if expr.endswith("[*]"):
        if not expr.startswith("@."):
            return 1
        base = expr[2:-3]  # drop @. and [*]
        keys = base.split(".")
        cur = walk(data, keys)
        if isinstance(cur, list):
            for item in cur:
                print(item)
            return 0
        return 1

    if not expr.startswith("@."):
        return 1
    keys = expr[2:].split(".")
    cur = walk(data, keys)
    if cur is None:
        return 1
    if isinstance(cur, list):
        return 0
    if isinstance(cur, dict):
        return 0
    if isinstance(cur, bool):
        print("true" if cur else "false")
    else:
        print(cur)
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except (OSError, json.JSONDecodeError, KeyError):
        sys.exit(1)
